# Price source
# kiwi_browser works without API keys. kiwi_api requires KIWI_API_KEY.
PRICE_SOURCE=kiwi_browser

# Kiwi settings
KIWI_API_KEY=
KIWI_BASE_URL=https://api.tequila.kiwi.com
BROWSER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_SECONDS=60
ILS_PER_USD=3.60

# Telegram bot settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Files
ROUTES_FILE=routes.json
PRICES_CSV=prices.csv

# Default flight search settings.
# Each route in routes.json can override these values.
CURRENCY=USD
ALERT_THRESHOLD=1000
ADULTS=1
MAX_RESULTS=20
NOTIFY_EVERY_CHECK=true

# Monitoring settings
CHECK_INTERVAL_SECONDS=7200
REQUEST_TIMEOUT_SECONDS=30
